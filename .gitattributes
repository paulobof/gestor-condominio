# Default: detect text, normalize to LF on commit, keep LF on checkout
* text=auto eol=lf

# Force LF for source code
*.java       text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.js         text eol=lf
*.jsx        text eol=lf
*.json       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.css        text eol=lf
*.html       text eol=lf
*.md         text eol=lf
*.sh         text eol=lf
*.xml        text eol=lf
*.properties text eol=lf
mvnw         text eol=lf
.husky/*     text eol=lf

# Force CRLF for Windows batch
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
