# =====================================================================
# Backend — variáveis de ambiente (Dokploy) — TEMPLATE PROD
# Domínio de produção: helbortrilogyhome.com.br
#   frontend: https://www.helbortrilogyhome.com.br
#   api:      https://api.helbortrilogyhome.com.br
# Segredos marcados como GERAR_* devem ser gerados com `openssl rand -base64 32`
# e definidos APENAS no painel Dokploy (nunca commitados).
# =====================================================================

# Spring profile (prod ou hml)
SPRING_PROFILES_ACTIVE=prod

# Admin inicial (UNICO admin em prod; criado pelo seed Flyway V8 no primeiro boot).
# A seed grava must_change_password=true -> troca de senha OBRIGATORIA no 1o login.
# APP_ADMIN_INITIAL_PASSWORD e' so a senha temporaria (gerar e entregar com seguranca).
APP_ADMIN_EMAIL=contato@wizortech.com.br
APP_ADMIN_NAME=WizorTech
APP_ADMIN_INITIAL_PASSWORD=GERAR_SENHA_FORTE

# Seguranca de senha
APP_PASSWORD_PEPPER=GERAR_BASE64_32_BYTES
APP_PASSWORD_PEPPER_VERSION=1
APP_BCRYPT_STRENGTH=12

# JWT
APP_JWT_KEYS=v1:GERAR_BASE64_32_BYTES
APP_JWT_ACTIVE_KID=v1
APP_JWT_ISSUER=gestor-condominio
APP_JWT_AUDIENCE=gestor-condominio-web
APP_JWT_ACCESS_TTL=PT15M
APP_JWT_REFRESH_TTL=P7D

# CORS / Cookie (frontend de prod = app.helbortrilogyhome.com.br; www e' pagina de estacionamento)
APP_CORS_ALLOWED_ORIGINS=https://app.helbortrilogyhome.com.br
APP_COOKIE_DOMAIN=helbortrilogyhome.com.br
APP_COOKIE_SECURE=true

# Postgres (Dokploy resolve nome do servico)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gestor_condominio
POSTGRES_USER=condominio
POSTGRES_PASSWORD=GERAR_SENHA_FORTE

# MinIO (compose)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=condominio
MINIO_SECRET_KEY=GERAR_SENHA_FORTE
MINIO_BUCKET_PROOFS=residence-proofs
MINIO_BUCKET_CLASSIFIEDS=classifieds
MINIO_BUCKET_RECOMMENDATIONS=recommendations
MINIO_BUCKET_DOCUMENTS=documents
MINIO_PRESIGNED_TTL_PROOFS_SECONDS=300
MINIO_PRESIGNED_TTL_PHOTOS_SECONDS=600

# WhatsApp via Evolution API
APP_WHATSAPP_BASE_URL=https://evo.paulobof.com.br
APP_WHATSAPP_API_KEY=DEFINIR_NO_DOKPLOY
APP_WHATSAPP_INSTANCE=Bot-Robo
APP_WHATSAPP_TIMEOUT_MS=5000
APP_WHATSAPP_MAX_RETRIES=3
APP_WHATSAPP_RETRY_INTERVAL_MS=1000

# Reset de senha (aponta para o frontend de prod)
APP_PASSWORD_RESET_TTL=PT30M
APP_PASSWORD_RESET_BASE_URL=https://app.helbortrilogyhome.com.br/reset

# Indicações: link de consentimento WhatsApp (DEVE apontar p/ frontend de prod)
APP_RECOMMENDATION_CONSENT_BASE_URL=https://app.helbortrilogyhome.com.br/indicacoes/pendentes

# LGPD
APP_DPO_EMAIL=privacidade@helbortrilogyhome.com.br
APP_CONTROLLER_NAME=Condominio HELBOR TRILOGY HOME
APP_CONTROLLER_CNPJ=00.000.000/0001-00
APP_PROOF_RETENTION_DAYS=180
APP_INACTIVE_ACCOUNT_MONTHS=12

# ---------------------------------------------------------------------
# Feature flags — RELEASE INICIAL: TODAS LIGADAS (9 flags)
# Mudanca de flag em prod deve ser registrada em issue do GitHub
# (actor, flag, from, to, motivo) — ver CLAUDE.md.
# ---------------------------------------------------------------------
APP_FEATURE_CLASSIFIEDS_ENABLED=true
APP_FEATURE_RECOMMENDATIONS_ENABLED=true
APP_FEATURE_ANNOUNCEMENTS_ENABLED=true
APP_FEATURE_FAQ_ENABLED=true
APP_FEATURE_GENERALINFO_ENABLED=true
APP_FEATURE_PARKINGRENTAL_ENABLED=true
APP_FEATURE_UNITOWNERSHIP_ENABLED=true
APP_FEATURE_DOCUMENTS_ENABLED=true
APP_FEATURE_ACCESSMANAGEMENT_ENABLED=true

# Alertas
APP_ALERT_EMAIL=paulobof@gmail.com

# Avisos de atividade (criar/editar/excluir) no grupo WhatsApp de admins
APP_ALERTS_WHATSAPP_ENABLED=true
APP_ALERTS_WHATSAPP_GROUP_JID=120363409829888116@g.us

# Observabilidade
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
