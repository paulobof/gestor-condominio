# Build args do servico frontend (Dokploy). Sao consumidos no BUILD da imagem
# (Vite + sed na CSP do nginx), entao trocar qualquer um exige REBUILD do frontend.

# Base da API. IMPORTANTE: terminar com /api — o backend serve todos os endpoints
# sob /api e o frontend apenda os caminhos (ex: {base}/privacy/document/current).
VITE_API_BASE_URL=https://api.helbortrilogyhome.com.br/api

# Origem da API liberada na CSP (connect-src/img-src), POR AMBIENTE.
# prod: https://*.helbortrilogyhome.com.br   | hml: https://*.helbor.paulobof.com.br
# NUNCA misturar dominios de ambientes diferentes.
CSP_API_ORIGIN=https://*.helbortrilogyhome.com.br
